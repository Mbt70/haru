# 복사해서 .env.local 로 저장하고 실제 값을 채울 것
# Supabase 대시보드 → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 웹 푸시(VAPID) — `npx web-push generate-vapid-keys`로 생성
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# 리마인더 예약 발송 (cron이 /api/cron/reminders 호출)
CRON_SECRET=
# 아래는 Vercel 환경변수에만 (절대 NEXT_PUBLIC_ 아님) — Supabase 대시보드 service_role 키
SUPABASE_SERVICE_ROLE_KEY=

# 구글 캘린더 OAuth (Google Cloud Console → Credentials → OAuth client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
